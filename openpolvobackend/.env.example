# Se :8080 estiver ocupado (ex.: Apache), usa :8081 e define VITE_API_BASE_URL=http://127.0.0.1:8081 no front.
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Electron empacotado (file://) envia origem "null"; desligue em produção pública se necessário
CORS_ALLOW_NULL_ORIGIN=true

# Gere um segredo forte (não commite o .env real)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=open-polvo
JWT_ACCESS_TTL=15m

# Opcional: chave de 32 bytes (base64) para encriptar passwords SMTP em laele_user_smtp_settings.
# Se omitir, a chave deriva de JWT_SECRET (adequado a dev; em produção prefira SMTP_CREDENTIALS_KEY).
# SMTP_CREDENTIALS_KEY=
#
# Ligação aos servidores SMTP (teste/envio por utilizador): timeout e família de IP.
# SMTP_DIAL_TIMEOUT=30s
# SMTP_DIAL_NETWORK=tcp
# Se a rede quebra IPv6 para o servidor SMTP mas IPv4 funciona:
# SMTP_PREFER_IPV4=true
# (equivale a SMTP_DIAL_NETWORK=tcp4)

# Base de dados local (SQLite). Caminho relativo à raiz do módulo Go (pasta com go.m) ou absoluto.
# Instalação local do agente: um ficheiro .db por máquina/utilizador.
DB_PATH=openpolvo.db

# Primeira instalação: mantém true para aplicar todas as migrações ao arrancar (idempotente).
# Só defines false se gerires o schema manualmente; em dev local evita -SkipMigrate no script se a base for nova.
RUN_MIGRATIONS=true
MIGRATIONS_PATH=migrations

# Automação Playwright (Pulo do Gato)
# AUTOMATION_ENABLED=true
# AUTOMATION_HEADLESS=true
# Hosts extra permitidos para nós goto (além da lista interna de plugins), separados por vírgula:
# AUTOMATION_ALLOWED_HOSTS=example.com,app.cliente.pt
#
# Agendamento de workflows (cron no processo Go — robfig/cron; não requer Temporal.io)
# WORKFLOW_SCHEDULER_ENABLED=true
# Intervalo entre verificações (mín. 10s recomendado)
# WORKFLOW_SCHEDULER_INTERVAL=45s

# Fila de execuções (recomendado): torna tasks/workflows agendados idempotentes e resistentes a drift.
# SCHED_QUEUE_ENABLED=true
# Número de workers consumindo a fila (1-16).
# SCHED_QUEUE_WORKERS=2
# Intervalo de polling da fila.
# SCHED_QUEUE_POLL_INTERVAL=2s
# TTL do lock por item em execução (evita duplicação entre workers).
# SCHED_QUEUE_LOCK_TTL=10m
# Após migrações: criar admin inicial se ainda não existir (idempotente).
BOOTSTRAP_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@openlaele.local
# Obrigatório se BOOTSTRAP_DEFAULT_ADMIN=true (troca por uma password forte; não uses o exemplo em produção).
DEFAULT_ADMIN_PASSWORD=ChangeMeLocalDev_Only

# Registo público desligado por defeito (recomendado em produção)
AUTH_ALLOW_REGISTER=false

# ─────────────────────────────────────────────────────────────────
# Open Polvo Intelligence (Python + LangGraph) — obrigatório para chat e LLM de workflows
# ─────────────────────────────────────────────────────────────────
POLVO_INTELLIGENCE_BASE_URL=http://127.0.0.1:8090
POLVO_INTELLIGENCE_INTERNAL_KEY=change-me-same-as-POLVO_INTERNAL_KEY-in-Python

# Timeout HTTP para chamadas ao serviço Intelligence (reply, generate, llm nodes).
# Timeout para chamadas ao motor Python (respostas longas / streaming).
AGENT_LLM_TIMEOUT=600s

# Legado: chaves no processo Go já não activam o agente (configure no serviço Python).
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
#
# Transcrição de voz (POST /v1/audio/transcribe): multimodal no Gemini; Whisper ou modelos novos na OpenAI.
# GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─────────────────────────────────────────────────────────────────
# Integração Meta (WhatsApp Business, Facebook Pages, Instagram Business)
# ─────────────────────────────────────────────────────────────────
# Chave AES-256 para cifrar tokens Meta por utilizador (se vazia deriva de JWT_SECRET).
# META_CREDENTIALS_KEY=
#
# Token de verificação do webhook Meta (hub.verify_token) — mesma string configurada
# no painel Meta App > Webhook.
# META_WEBHOOK_VERIFY_TOKEN=change-me-random-webhook-token
#
# URL de webhook a registar no painel Meta (sem autenticação, método GET+POST):
#   GET/POST https://<tua-api>/meta/webhook

# Opcional: rastreio LangSmith (não obrigatório para o chat)
# LANGCHAIN_API_KEY=
# LANGSMITH_API_KEY=

# Seed opcional (openlaele-seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=
