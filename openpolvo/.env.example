# URL base da API Go (sem barra final). Opcional: se omitir, o front usa http://127.0.0.1:8081
# (alinhar com HTTP_ADDR no `.env` do backend, ex. :8081).
# VITE_API_BASE_URL=http://127.0.0.1:8081

# Versão web — painel de plugins: botão "Baixar versão desktop" aponta para esta URL (releases ou instalador).
# VITE_DESKTOP_DOWNLOAD_URL=https://exemplo.org/open-polvo/releases/latest

# Electron (legado): opcional no processo principal; empacotado usa userData/backend.env injectado no renderer.
# OPEN_LA_ELE_API_URL=http://127.0.0.1:8081

# Processo principal (Electron): portas onde corre o Vite de *preview* isolado — injecta CSP estrita.
# O Vite da shell em :5174 não deve estar nesta lista. Exporte no ambiente antes de `npm run dev` se necessário.
# OPEN_POLVO_PREVIEW_CSP_PORTS=5175,5180,5176,4174
