# URL base da API Go (sem barra final). Opcional: se omitir, o front usa http://127.0.0.1:8080
# (o mesmo host que o backend com HTTP_ADDR=:8080 na raiz do monorepo).
# VITE_API_BASE_URL=http://127.0.0.1:8080

# Versão web — painel de plugins: botão "Baixar versão desktop" aponta para esta URL (releases ou instalador).
# VITE_DESKTOP_DOWNLOAD_URL=https://exemplo.org/open-polvo/releases/latest

# Electron: opcional no processo principal (sobrepõe quando definido e VITE_API_BASE_URL vazio):
# OPEN_LA_ELE_API_URL=http://127.0.0.1:8080
