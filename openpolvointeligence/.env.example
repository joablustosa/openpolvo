# Copie para .env e preencha (não commite o ficheiro .env).
# POLVO_INTERNAL_KEY deve coincidir com POLVO_INTELLIGENCE_INTERNAL_KEY na API Go.
POLVO_INTERNAL_KEY=change-me-same-as-POLVO_INTELLIGENCE_INTERNAL_KEY-in-Go

# Pelo menos uma chave LLM (deixe em branco a que não usar).
OPENAI_API_KEY=
# GOOGLE_API_KEY=

OPENAI_MODEL=gpt-4o-mini
GOOGLE_MODEL=gemini-2.0-flash
AGENT_LLM_TIMEOUT_S=120

# SerpAPI (opcional) — igual à API Go. Se definido, o Zé Polvinho usa um pipeline LangGraph
# multi-etapas para a intenção `pesquisa_web_tempo_real` (planeamento + buscas + síntese + crítica).
# SERPAPI_API_KEY=
# SERPAPI_DDG_KL=pt-pt
# SERPAPI_DDG_SAFE=0

# Opcional — aprofundamento: quantas URLs dos resultados orgânicos visitar (fetch + sub-grafo por site).
# WEB_RESEARCH_MAX_DEEP_URLS=4
# WEB_FETCH_TIMEOUT_S=18
# WEB_FETCH_MAX_RESPONSE_BYTES=600000
# WEB_FETCH_MAX_TEXT_CHARS=24000

HOST=127.0.0.1
PORT=8090
